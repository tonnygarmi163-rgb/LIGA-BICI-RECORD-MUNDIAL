<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Liga Bici</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --bg:#f0f0f0;--white:#fff;--black:#0b0b0c;
  --red:#e02020;--blue:#1e40ff;--yellow:#f5c800;--green:#16a34a;--orange:#f97316;
  --gray1:#f8f8f8;--gray2:#e8e8e8;--gray3:#d0d0d0;--gray4:#a0a0a0;--gray5:#555;
  --nav-h:64px;
}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg);color:var(--black);min-height:100vh;overflow-y:auto;-webkit-overflow-scrolling:touch}
.screen{display:none;min-height:100vh;padding-bottom:calc(var(--nav-h) + 24px)}.screen.active{display:block;animation:fadeSlideIn .2s ease}
@keyframes fadeSlideIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.season-switcher{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;padding:14px 14px 0;position:sticky;top:0;z-index:100;background:var(--bg)}
.season-card{background:var(--gray2);border:none;border-radius:12px;padding:12px 10px;text-align:left;cursor:pointer;transition:all .15s}
.season-card.active{background:var(--black);color:var(--white)}
.season-card .season-kicker{font-size:9px;letter-spacing:2px;text-transform:uppercase;opacity:.6;display:block;margin-bottom:2px}
.season-card strong{display:block;font-size:14px;font-weight:800}
.season-card span{font-size:12px;opacity:.7}
.brand-panel{background:var(--white);border-radius:12px;margin:12px 14px 0;padding:16px;display:flex;align-items:center;gap:14px;box-shadow:0 1px 3px rgba(0,0,0,.08)}
.brand-logo{width:60px;height:60px;background:var(--black);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.brand-logo svg{width:44px;height:44px}
.brand-info .eyebrow{font-size:11px;color:var(--gray4);letter-spacing:2px;text-transform:uppercase;font-weight:600}
.brand-info h1{font-size:22px;font-weight:900;line-height:1.1}
.brand-info .season-summary{font-size:12px;color:var(--gray5);margin-top:3px}
.quick-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin:10px 14px 0}
.qs-box{background:var(--white);border-radius:10px;padding:12px;text-align:center;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.qs-val{font-size:20px;font-weight:900}.qs-lbl{font-size:9px;color:var(--gray4);text-transform:uppercase;letter-spacing:1px;margin-top:1px}
.section-block{margin:14px 14px 0}
.section-heading{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.section-heading h2{font-size:16px;font-weight:800}
.text-link{background:none;border:none;color:var(--blue);font-size:13px;font-weight:600;cursor:pointer;padding:0}
.event-item{background:var(--white);border-radius:10px;padding:12px 14px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;box-shadow:0 1px 3px rgba(0,0,0,.06);cursor:pointer;transition:transform .1s}
.event-item:active{transform:scale(.98)}
.ei-name{font-size:14px;font-weight:700}.ei-date{font-size:12px;color:var(--gray4);margin-top:2px}
.ei-status{font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px}
.status-done{color:var(--green);background:#dcfce7}.status-next{color:var(--blue);background:#dbeafe}.status-pend{color:var(--gray4);background:var(--gray2)}
.leader-item{background:var(--white);border-radius:10px;padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;gap:12px;box-shadow:0 1px 3px rgba(0,0,0,.06);cursor:pointer;transition:transform .1s}
.leader-item:active{transform:scale(.98)}
.li-pos{font-size:20px;font-weight:900;width:24px;text-align:center}.li-bar{width:3px;height:36px;border-radius:2px;flex-shrink:0}.li-name{flex:1;font-size:14px;font-weight:700}.li-pts{font-size:22px;font-weight:900}
.bottom-nav{position:fixed;bottom:0;left:0;right:0;background:var(--black);display:flex;height:var(--nav-h);z-index:200;border-top:1px solid #222}
.nav-button{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;background:none;border:none;color:#888;font-size:9px;font-weight:600;letter-spacing:.5px;cursor:pointer;padding:6px 2px;transition:color .15s;text-transform:uppercase;min-height:48px}
.nav-button.active{color:var(--white)}.nav-button svg{width:20px;height:20px}
.view-header{padding:20px 14px 10px}
.view-header .eyebrow{font-size:11px;color:var(--gray4);letter-spacing:2px;text-transform:uppercase;font-weight:600}
.view-header h1{font-size:26px;font-weight:900;margin-top:2px}
.search-bar{margin:0 14px 10px;position:relative}
.search-bar input{width:100%;padding:10px 14px 10px 36px;border:2px solid var(--gray2);border-radius:10px;font-size:14px;background:var(--white);color:var(--black);outline:none;transition:border-color .2s}
.search-bar input:focus{border-color:var(--blue)}
.search-bar svg{position:absolute;left:10px;top:50%;transform:translateY(-50%);width:18px;height:18px;color:var(--gray4)}
.participant-card{background:var(--white);border-radius:12px;margin:0 14px 10px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.08);cursor:pointer;transition:transform .1s}
.participant-card:active{transform:scale(.98)}
.pc-header{padding:14px 16px;display:flex;justify-content:space-between;align-items:flex-start}
.pc-kicker{font-size:11px;font-weight:600;opacity:.85}.pc-name{font-size:24px;font-weight:900;letter-spacing:.5px}.pc-dorsal{font-size:32px;font-weight:900;opacity:.4}
.pc-stats{display:grid;grid-template-columns:repeat(5,1fr);border-top:1px solid var(--gray2)}
.pc-stat{padding:10px 4px;text-align:center;border-right:1px solid var(--gray2);display:flex;flex-direction:column;justify-content:center}.pc-stat:last-child{border-right:none}
.pc-sv{font-size:16px;font-weight:900;line-height:1.2}.pc-sl{font-size:8px;color:var(--gray4);text-transform:uppercase;letter-spacing:.5px;margin-top:2px}
.standing-row{background:var(--white);border-radius:10px;margin:0 14px 8px;padding:14px 16px;display:flex;align-items:center;gap:14px;box-shadow:0 1px 3px rgba(0,0,0,.06);border-left:4px solid;cursor:pointer;transition:transform .1s}
.standing-row:active{transform:scale(.98)}
.sr-num{width:32px;height:32px;border-radius:50%;background:var(--black);color:var(--white);display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:900;flex-shrink:0}
.sr-info{flex:1}.sr-name{font-size:16px;font-weight:800}.sr-diff{font-size:12px;color:var(--gray4);margin-top:1px}.sr-pts{font-size:26px;font-weight:900}
.score-section{margin:14px 14px 0}
.score-player{background:var(--white);border-radius:10px;margin-bottom:10px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.sp-header{padding:12px 16px;display:flex;justify-content:space-between;align-items:center}.sp-name{font-size:16px;font-weight:800}.sp-total{font-size:22px;font-weight:900}
.sp-row{display:flex;justify-content:space-between;align-items:center;padding:9px 16px;border-top:1px solid var(--gray2)}
.spr-circ{font-size:13px;font-weight:500}.spr-right{display:flex;align-items:center;gap:8px}
.tag-carrera{background:var(--red);color:var(--white);font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px}
.tag-tiempos{background:var(--yellow);color:var(--black);font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px}
.tag-practica{background:var(--green);color:var(--white);font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px}
.spr-pts{font-size:13px;font-weight:800}
.filter-row{display:flex;gap:8px;overflow-x:auto;padding:0 14px 10px;scrollbar-width:none}
.filter-row::-webkit-scrollbar{display:none}
.filter-pill{background:var(--gray2);border:none;border-radius:20px;padding:6px 14px;font-size:12px;font-weight:600;cursor:pointer;white-space:nowrap;color:var(--gray5);min-height:36px}
.filter-pill.active{background:var(--black);color:var(--white)}
.circ-card{background:var(--white);border-radius:12px;margin:0 14px 12px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.08);cursor:pointer;transition:transform .1s}
.circ-card:active{transform:scale(.98)}
.circ-header-bar{padding:10px 14px 8px;display:flex;justify-content:space-between;align-items:center}
.ch-label{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase}
.ch-badge{font-size:10px;font-weight:700;padding:2px 10px;border-radius:10px;text-transform:uppercase}
.badge-circuit{background:var(--red);color:var(--white)}
.circ-drawing{height:200px;display:flex;align-items:center;justify-content:center;padding:0;background:var(--gray1);position:relative;overflow:hidden}
.circ-drawing svg{max-width:100%;max-height:100%}
.circ-drawing img{width:100%;height:100%;object-fit:contain;display:block;background:#fff;padding:8px;box-sizing:border-box}
.circ-info{padding:10px 14px}
.ci-name{font-size:18px;font-weight:900}.ci-record{font-size:13px;color:var(--gray4);float:right;margin-top:2px}
.ci-desc{font-size:12px;color:var(--gray5);margin-top:4px;line-height:1.5}
.ci-summary{font-size:11px;color:var(--blue);margin-top:6px;line-height:1.4;font-style:italic}
.ci-tags{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px}
.ci-tag{font-size:10px;font-weight:700;padding:3px 10px;border-radius:6px;text-transform:uppercase;letter-spacing:.5px}
.tag-tranquilo{background:#dcfce7;color:#15803d}.tag-coches{background:#fef9c3;color:#854d0e}.tag-peatones{background:#dbeafe;color:#1e40af}
.tag-dif-media{background:#f3f4f6;color:#374151}.tag-dif-alta{background:#fee2e2;color:#b91c1c}.tag-dif-baja{background:#f0fdf4;color:#15803d}
.tag-riesgo-bajo{background:#f0fdf4;color:#15803d}.tag-riesgo-medio{background:#fff7ed;color:#c2410c}.tag-riesgo-alto{background:#fee2e2;color:#b91c1c}
.hor-item{background:var(--white);border-radius:12px;margin:0 14px 10px;display:flex;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.hi-date{background:var(--black);color:var(--white);width:64px;flex-shrink:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 4px;text-align:center}
.hi-day{font-size:22px;font-weight:900;line-height:1}.hi-month{font-size:10px;text-transform:uppercase;letter-spacing:1px;opacity:.7;margin-top:2px}
.hi-body{flex:1;padding:12px 14px}.hi-name{font-size:15px;font-weight:800}.hi-sub{font-size:12px;color:var(--gray5);margin-top:2px}
.hi-actions{display:flex;gap:8px;margin-top:10px}
.btn-carrera{background:var(--red);color:var(--white);border:none;border-radius:20px;padding:6px 14px;font-size:11px;font-weight:700;cursor:pointer;text-transform:uppercase}
.btn-practica{background:var(--green);color:var(--white);border:none;border-radius:20px;padding:6px 14px;font-size:11px;font-weight:700;cursor:pointer;text-transform:uppercase}
.btn-tiempos{background:var(--yellow);color:var(--black);border:none;border-radius:20px;padding:6px 14px;font-size:11px;font-weight:700;cursor:pointer;text-transform:uppercase}
.btn-ver-circ{background:var(--black);color:var(--white);border:none;border-radius:20px;padding:6px 14px;font-size:11px;font-weight:700;cursor:pointer}
.hi-status{font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;align-self:flex-start;margin-top:12px;margin-right:10px;flex-shrink:0}
.gala-item{background:linear-gradient(135deg,#1a1a1a,#2d2d2d);border:2px solid #d4a017;border-radius:12px;margin:0 14px 12px;display:flex;align-items:center;gap:12px;padding:14px 16px;box-shadow:0 2px 8px rgba(212,160,23,0.15)}
.gala-icon{font-size:32px}.gala-text .gala-title{font-size:16px;font-weight:900;color:#d4a017;text-transform:uppercase;letter-spacing:1px}.gala-text .gala-date{font-size:12px;color:#f5d76e;margin-top:2px}
.info-tabs{display:flex;gap:0;margin:0 14px 14px;background:var(--gray2);border-radius:10px;padding:3px}
.info-tab{flex:1;background:none;border:none;border-radius:8px;padding:8px;font-size:12px;font-weight:700;cursor:pointer;color:var(--gray5);min-height:36px}
.info-tab.active{background:var(--white);color:var(--black);box-shadow:0 1px 3px rgba(0,0,0,.1)}
.info-panel{margin:0 14px}
.norma-section{background:var(--white);border-radius:12px;padding:14px;margin-bottom:10px;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.ns-title{font-size:14px;font-weight:800;margin-bottom:8px;display:flex;align-items:center;gap:6px}
.ns-body{font-size:13px;color:var(--gray5);line-height:1.65}
.ns-body ul{padding-left:18px;margin-top:6px}.ns-body li{margin-bottom:4px}
.ns-highlight{background:#f0fdf4;border-left:3px solid var(--green);padding:8px 12px;border-radius:0 6px 6px 0;margin-top:8px;font-size:13px}
.ns-pole{background:#fefce8;border-left:3px solid #ca8a04;padding:8px 12px;border-radius:0 6px 6px 0;margin-top:8px;font-size:13px}
.comp-section{margin:0 14px 14px}
.comp-table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch}
.comp-table{width:100%;border-collapse:collapse;font-size:12px;background:var(--white);border-radius:10px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.comp-table th{background:var(--black);color:var(--white);padding:10px 8px;text-align:left;font-size:11px;letter-spacing:.5px;text-transform:uppercase;white-space:nowrap}
.comp-table td{padding:10px 8px;border-bottom:1px solid var(--gray2);vertical-align:top}
.comp-table tr:last-child td{border-bottom:none}
.comp-table .bike-label{font-weight:700;font-size:13px;white-space:nowrap}
.comp-table .pilot-name{font-size:11px;color:var(--gray4);display:block;margin-top:2px}
.comp-table .status-ok{color:var(--green);font-weight:700}
.comp-table .status-warn{color:#ca8a04;font-weight:700}
.comp-table .status-bad{color:var(--red);font-weight:700}
.comp-subtitle{font-size:13px;font-weight:800;color:var(--gray4);letter-spacing:1px;text-transform:uppercase;margin:18px 0 10px}
.comp-pros-cons{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:0 14px 14px}
.comp-pro,.comp-con{background:var(--white);border-radius:10px;padding:12px;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.comp-pro{border-left:3px solid var(--green)}.comp-con{border-left:3px solid var(--red)}
.comp-pro h4,.comp-con h4{font-size:12px;font-weight:800;margin-bottom:6px}
.comp-pro ul,.comp-con ul{padding-left:14px;font-size:12px;color:var(--gray5);line-height:1.6}
.comp-formula{background:var(--gray1);border-radius:10px;padding:14px;margin:0 14px 14px;text-align:center}
.comp-formula code{font-size:15px;font-weight:700;color:var(--blue)}
.comp-formula .formula-lbl{font-size:11px;color:var(--gray4);margin-top:4px}
.noticia-card{background:var(--white);border-radius:12px;padding:14px;margin-bottom:10px;box-shadow:0 1px 3px rgba(0,0,0,.06);overflow:hidden;cursor:pointer}
.noticia-card:active{transform:scale(.98)}
.noticia-img{background:linear-gradient(135deg,#1e40ff,#0b0b0c);height:100px;border-radius:8px;margin-bottom:10px;display:flex;align-items:center;justify-content:center;font-size:40px;overflow:hidden}
.noticia-img img{width:100%;height:100%;object-fit:cover}
.noticia-fecha{font-size:10px;color:var(--gray4);text-transform:uppercase;letter-spacing:1px;font-weight:600}
.noticia-title{font-size:16px;font-weight:800;margin-top:4px}
.noticia-body{font-size:13px;color:var(--gray5);margin-top:6px;line-height:1.6}
.video-note{background:#dbeafe;border-radius:10px;padding:12px 14px;font-size:13px;color:#1e40af;font-weight:500;margin:0 14px 14px;display:flex;gap:8px}
.vcard{background:var(--white);border-radius:12px;margin:0 14px 10px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.vcard-thumb{height:100px;display:flex;align-items:center;justify-content:center;position:relative}
.vcard-play{width:42px;height:42px;background:var(--red);border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--white);font-size:16px}
.vcard-info{padding:10px 14px}.vcard-title{font-size:14px;font-weight:700}.vcard-meta{font-size:12px;color:var(--gray4);margin-top:2px}
.detail-dialog{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:500;display:none;align-items:flex-end;justify-content:center}
.detail-dialog.open{display:flex}
.dialog-content{background:var(--white);border-radius:20px 20px 0 0;width:100%;max-height:85vh;overflow-y:auto;position:relative;-webkit-overflow-scrolling:touch}
.close-btn{position:sticky;top:12px;float:right;background:var(--gray2);border:none;width:32px;height:32px;border-radius:50%;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:10;margin:12px 12px 0 0}
.dlg-player-header{padding:20px 16px 16px}
.dph-eyebrow{font-size:10px;letter-spacing:2px;text-transform:uppercase;font-weight:700;opacity:.7}
.dph-name{font-size:28px;font-weight:900;margin-top:4px}
.dlg-bici-row{display:flex;align-items:center;gap:12px;padding:12px 16px;background:var(--gray1);border-radius:10px;margin:0 16px 14px;cursor:pointer;border:1.5px solid var(--gray2);transition:border-color .15s}
.dlg-bici-row:hover{border-color:#1e40ff}
.dbr-img{width:80px;height:48px;display:flex;align-items:center;justify-content:center;background:var(--gray2);border-radius:8px;flex-shrink:0;overflow:hidden}
.dbr-img img{width:100%;height:100%;object-fit:contain}
.dbr-model{font-size:14px;font-weight:700}.dbr-link{font-size:11px;color:var(--blue);font-weight:600;margin-top:2px}
.dlg-stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--gray2);border-radius:10px;overflow:hidden;margin:0 16px 14px}
.dsg-box{background:var(--white);padding:12px}.dsg-val{font-size:20px;font-weight:900}.dsg-lbl{font-size:10px;color:var(--gray4);text-transform:uppercase;letter-spacing:.5px;margin-top:2px}
.dlg-wins-title{font-size:13px;font-weight:800;color:var(--gray4);letter-spacing:1px;text-transform:uppercase;padding:0 16px;margin-bottom:8px}
.win-chips{display:flex;flex-wrap:wrap;gap:6px;padding:0 16px 16px}
.win-chip{background:var(--gray2);border-radius:20px;padding:5px 12px;font-size:12px;font-weight:600;cursor:pointer;border:none}
.win-chip .wc-season{font-size:10px;color:var(--gray4);display:block;margin-top:1px}
.bici-hero{text-align:center;padding:20px 16px 10px;background:var(--gray1)}
.bici-hero img{width:280px;height:180px;object-fit:contain;border-radius:8px}
.bici-model-title{font-size:20px;font-weight:900;padding:14px 16px 2px}
.bici-type-sub{font-size:13px;color:var(--gray4);padding:0 16px 14px}
.bici-specs{margin:0 16px 10px}
.bici-spec-row{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--gray2)}
.bici-spec-row:last-child{border-bottom:none}
.bsr-label{font-size:12px;color:var(--gray4);font-weight:500}.bsr-val{font-size:13px;font-weight:700;text-align:right;max-width:60%}
.bici-price{background:var(--black);color:var(--white);margin:0 16px 10px;border-radius:10px;padding:12px 16px;display:flex;justify-content:space-between;align-items:center}
.bp-label{font-size:12px;opacity:.6}.bp-price{font-size:20px;font-weight:900}
.btn-shop{display:block;margin:0 16px 16px;background:var(--blue);color:var(--white);border:none;border-radius:10px;padding:12px;font-size:14px;font-weight:700;cursor:pointer;text-align:center;text-decoration:none;width:calc(100% - 32px);min-height:48px;display:flex;align-items:center;justify-content:center}
.btn-shop.no-link{background:var(--gray3);color:var(--gray5);cursor:not-allowed}
.dlg-circ-drawing{height:150px;background:var(--gray1);display:flex;align-items:center;justify-content:center;padding:10px}
.dlg-circ-drawing svg{max-width:100%;max-height:100%}
.dlg-circ-label{font-size:10px;color:var(--gray4);letter-spacing:2px;text-transform:uppercase;font-weight:700;padding:14px 16px 2px}
.dlg-circ-name{font-size:24px;font-weight:900;padding:0 16px 6px}
.dlg-circ-desc{font-size:13px;color:var(--gray5);padding:0 16px 14px;line-height:1.6}
.dlg-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--gray2);margin:0 16px 14px;border-radius:10px;overflow:hidden}
.dig-box{background:var(--white);padding:10px 12px}.dig-val{font-size:15px;font-weight:800}.dig-lbl{font-size:10px;color:var(--gray4);text-transform:uppercase;letter-spacing:.5px;margin-top:2px}
.dlg-ganadores{padding:0 16px;margin-bottom:14px}
.dg-title{font-size:13px;font-weight:800;color:var(--gray4);letter-spacing:1px;text-transform:uppercase;margin-bottom:8px}
.dg-chip{background:var(--gray2);border-radius:6px;padding:5px 12px;display:inline-block;margin:3px 4px 3px 0;font-size:12px;font-weight:700}
.dlg-tiempos{padding:0 16px 16px}
.dt-item{background:var(--gray1);border-radius:8px;padding:10px 14px;margin-bottom:6px;display:flex;justify-content:space-between;font-size:13px;font-weight:600}
.dlg-actions{display:flex;gap:10px;padding:0 16px 20px}
.btn-back{background:var(--gray2);color:var(--black);border:none;border-radius:20px;padding:10px 20px;font-size:13px;font-weight:700;cursor:pointer;flex:1;min-height:48px}
.btn-mymaps{background:var(--black);color:var(--white);border:none;border-radius:20px;padding:10px 20px;font-size:13px;font-weight:700;cursor:pointer;flex:1;min-height:48px}
.dialog-content::-webkit-scrollbar{width:6px}
.dialog-content::-webkit-scrollbar-track{background:var(--gray2)}
.dialog-content::-webkit-scrollbar-thumb{background:var(--gray4);border-radius:4px}
.toast{position:fixed;bottom:calc(var(--nav-h) + 16px);left:50%;transform:translateX(-50%);background:var(--black);color:var(--white);padding:12px 20px;border-radius:10px;font-size:13px;font-weight:600;z-index:1000;opacity:0;transition:opacity .3s;pointer-events:none;text-align:center;max-width:90%}
.toast.show{opacity:1}
.empty-state{text-align:center;padding:40px 20px;color:var(--gray4)}
.empty-state .emoji{font-size:48px;display:block;margin-bottom:12px}
.empty-state p{font-size:14px}
.dev-badge{display:inline-block;font-size:10px;font-weight:600;padding:2px 8px;border-radius:10px;margin-top:4px}
.dev-subida{background:#f0fdf4;color:#15803d}
.dev-velocidad{background:#dbeafe;color:#1e40af}
.dev-bajada{background:#fef3c7;color:#92400e}
.dev-freno{background:#fce7f3;color:#be185d}
.gama-badge{display:inline-block;font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px}
.gama-baja{background:#dcfce7;color:#15803d}
.gama-media{background:#fef9c3;color:#854d0e}
.gama-alta{background:#fee2e2;color:#b91c1c}
.gama-pro{background:#f3e8ff;color:#7c3aed}
.win-count-badge{background:var(--gray2);border-radius:20px;padding:2px 8px;font-size:11px;font-weight:600;margin-left:4px}
.bici-info-box{background:var(--white);border-radius:12px;margin:0 14px 14px;padding:16px;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.bici-info-box h3{font-size:15px;font-weight:800;margin-bottom:8px}
.bici-info-box p{font-size:13px;color:var(--gray5);line-height:1.6}
.bici-legend{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:0 14px 14px}
.legend-item{background:var(--white);border-radius:10px;padding:12px;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.legend-item .leg-icon{font-size:24px;margin-bottom:6px}
.legend-item h4{font-size:13px;font-weight:800;margin-bottom:4px}
.legend-item p{font-size:11px;color:var(--gray5);line-height:1.5}
.sort-controls{display:flex;align-items:center;gap:8px;margin:0 14px 14px;flex-wrap:wrap}
.sort-label{font-size:12px;font-weight:700;color:var(--gray5);margin-right:4px}
.sort-select{background:var(--white);border:2px solid var(--gray2);border-radius:10px;padding:8px 12px;font-size:13px;color:var(--black);cursor:pointer;outline:none}
.sort-select:focus{border-color:var(--blue)}
.sort-dir{background:var(--black);color:var(--white);border:none;border-radius:8px;padding:8px 14px;font-size:13px;font-weight:700;cursor:pointer}
.news-modal{position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:600;display:none;align-items:center;justify-content:center;padding:20px}
.news-modal.open{display:flex}
.news-modal-content{background:var(--white);border-radius:12px;max-width:600px;width:100%;max-height:90vh;overflow-y:auto;padding:20px;position:relative}
.news-modal-header{font-size:20px;font-weight:900;margin-bottom:10px}
.news-modal-date{font-size:12px;color:var(--gray4);margin-bottom:15px;text-transform:uppercase}
.news-modal-body{font-size:14px;line-height:1.6;color:var(--gray5)}
.news-modal-img{width:100%;height:200px;object-fit:cover;border-radius:8px;margin-bottom:15px}
.img-circuito{width:100%;height:100%;object-fit:contain;cursor:pointer;transition:transform .2s}
.img-circuito:hover{transform:scale(1.02)}
.google-earth-btn{position:absolute;bottom:10px;right:10px;background:#4285f4;color:#fff;padding:8px 14px;border-radius:8px;font-size:12px;font-weight:bold;text-decoration:none;display:flex;align-items:center;gap:6px;z-index:20;cursor:pointer;border:none;box-shadow:0 2px 6px rgba(0,0,0,0.3)}
.google-earth-btn:hover{background:#1e40ff}
.leyenda-container{margin:16px 14px 20px;background:var(--white);border-radius:12px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,.08)}
.leyenda-container h3{font-size:16px;font-weight:800;margin-bottom:12px;color:var(--black);display:flex;align-items:center;gap:8px}
.leyenda-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px}
.leyenda-item{display:flex;align-items:flex-start;gap:10px;background:var(--gray1);padding:10px;border-radius:8px;transition:background .2s}
.leyenda-item:hover{background:var(--gray2)}
.leyenda-item .icon{font-size:1.5rem;min-width:28px;text-align:center;line-height:1}
.leyenda-item .texto strong{display:block;font-size:12px;color:var(--black);margin-bottom:2px}
.leyenda-item .texto p{font-size:11px;color:var(--gray5);margin:0;line-height:1.3}
.circ-compare-header{padding:20px 14px 10px}
.circ-compare-header .eyebrow{font-size:11px;color:var(--gray4);letter-spacing:2px;text-transform:uppercase;font-weight:600}
.circ-compare-header h1{font-size:26px;font-weight:900;margin-top:2px}
.circ-compare-filters{display:flex;gap:8px;overflow-x:auto;padding:0 14px 14px;scrollbar-width:none}
.circ-compare-filters::-webkit-scrollbar{display:none}
.circ-compare-table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;margin:0 14px 14px}
.circ-compare-table{width:100%;border-collapse:collapse;font-size:12px;background:var(--white);border-radius:10px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.circ-compare-table th{background:var(--black);color:var(--white);padding:10px 8px;text-align:left;font-size:11px;letter-spacing:.5px;text-transform:uppercase;white-space:nowrap}
.circ-compare-table td{padding:10px 8px;border-bottom:1px solid var(--gray2);vertical-align:top}
.circ-compare-table tr:last-child td{border-bottom:none}
.circ-compare-table .bike-label{font-weight:700;font-size:13px;white-space:nowrap}
.circ-compare-table .pilot-name{font-size:11px;color:var(--gray4);display:block;margin-top:2px}
.circ-compare-table .status-ok{color:var(--green);font-weight:700}
.circ-compare-table .status-warn{color:#ca8a04;font-weight:700}
.circ-compare-table .status-bad{color:var(--red);font-weight:700}
.opinion-cell{font-size:11px;color:var(--gray5);max-width:150px;line-height:1.3}
.dificultad-cell{font-weight:700;font-size:14px;text-align:center}
