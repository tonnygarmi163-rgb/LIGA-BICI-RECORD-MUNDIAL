<div class="loading-screen" id="loadingScreen">
  <div class="animation-container">
    <div class="bike-loader">
      <div class="wheel wheel-front"></div>
      <div class="wheel wheel-back"></div>
      <div class="bike-frame"></div>
      <div class="rider-head"></div>
    </div>
    <div class="road-line"></div>
  </div>
  <div class="loading-content">
    <div class="loading-logo">LIGA BICI</div>
    <div class="loading-text">Preparando tu experiencia...</div>
    <div class="loading-progress">
      <div class="progress-bar"></div>
    </div>
  </div>
  <button class="skip-btn" id="skipBtn" onclick="skipLoading()">Saltar</button>
</div>

<style>
.loading-screen{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  z-index:9999;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  overflow:hidden;
}

.animation-container {
  position: relative;
  width: 300px;
  height: 200px;
  margin-bottom: 40px;
}

.bike-loader {
  position: relative;
  width: 100%;
  height: 100%;
  animation: bikeMove 0.5s ease-in-out infinite;
}

.wheel {
  position: absolute;
  width: 60px;
  height: 60px;
  border: 5px solid #fff;
  border-radius: 50%;
  bottom: 20px;
}

.wheel::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 40px;
  height: 40px;
  border: 3px solid rgba(255,255,255,0.3);
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.wheel::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 50px;
  height: 2px;
  background: rgba(255,255,255,0.5);
  transform-origin: center;
  animation: wheelSpin 1s linear infinite;
}

.wheel-front {
  right: 30px;
}

.wheel-back {
  left: 30px;
}

.bike-frame {
  position: absolute;
  width: 140px;
  height: 4px;
  background: #fff;
  top: 60px;
  left: 80px;
  transform-origin: left center;
  transform: rotate(-15deg);
}

.bike-frame::before {
  content: '';
  position: absolute;
  width: 80px;
  height: 4px;
  background: #fff;
  left: -40px;
  top: 0;
  transform: rotate(30deg);
  transform-origin: right center;
}

.rider-head {
  position: absolute;
  width: 30px;
  height: 30px;
  background: #fff;
  border-radius: 50%;
  top: 20px;
  left: 140px;
  animation: headBob 0.5s ease-in-out infinite;
}

.road-line {
  position: absolute;
  bottom: 10px;
  left: -100px;
  width: 500px;
  height: 2px;
  background: repeating-linear-gradient(
    90deg,
    #fff,
    #fff 20px,
    transparent 20px,
    transparent 40px
  );
  animation: roadMove 1s linear infinite;
}

.loading-content{
  position:relative;
  z-index:2;
  text-align:center;
  color:#fff;
}

.loading-logo{
  font-size:48px;
  font-weight:900;
  margin-bottom:20px;
  text-transform:uppercase;
  letter-spacing:3px;
  animation:pulse 2s ease-in-out infinite;
}

.loading-text{
  font-size:16px;
  opacity:0.9;
  margin-bottom:30px;
}

.loading-progress {
  width: 200px;
  height: 4px;
  background: rgba(255,255,255,0.2);
  border-radius: 2px;
  overflow: hidden;
  margin: 0 auto;
}

.progress-bar {
  height: 100%;
  background: #fff;
  width: 0%;
  animation: progress 5s ease-in-out forwards;
}

.skip-btn{
  position:fixed;
  bottom:30px;
  right:30px;
  background:rgba(255,255,255,0.2);
  backdrop-filter:blur(10px);
  color:#fff;
  border:2px solid rgba(255,255,255,0.5);
  padding:12px 30px;
  border-radius:30px;
  font-size:14px;
  font-weight:600;
  cursor:pointer;
  z-index:10;
  transition:all 0.3s ease;
  text-transform:uppercase;
  letter-spacing:1px;
}

.skip-btn:hover{
  background:rgba(255,255,255,0.3);
  transform:scale(1.05);
}

@keyframes bikeMove {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-5px); }
}

@keyframes wheelSpin {
  from { transform: translate(-50%, -50%) rotate(0deg); }
  to { transform: translate(-50%, -50%) rotate(360deg); }
}

@keyframes headBob {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-3px); }
}

@keyframes roadMove {
  from { transform: translateX(0); }
  to { transform: translateX(40px); }
}

@keyframes pulse{
  0%,100%{transform:scale(1);opacity:1;}
  50%{transform:scale(1.05);opacity:0.8;}
}

@keyframes progress {
  from { width: 0%; }
  to { width: 100%; }
}

.loading-screen.fade-out{
  opacity:0;
  pointer-events:none;
  transition:opacity 0.5s ease;
}
</style>
