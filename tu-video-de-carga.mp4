<div class="loading-screen" id="loadingScreen">
  <div class="video-loader">
    <iframe 
      src="https://drive.google.com/file/d/1kUk10XtEuDcbug50zVIlJOZqyy9P0Tk_/view?usp=sharing" 
      width="100%" 
      height="100%" 
      allow="autoplay"
      allowfullscreen>
    </iframe>
  </div>
  <div class="loading-content">
    <div class="loading-logo">LIGA BICI</div>
    <div class="loading-text">Cargando experiencia...</div>
    <button class="skip-btn" id="skipBtn" onclick="skipLoading()">Saltar</button>
  </div>
</div>

<style>
.loading-screen{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:#000;
  z-index:9999;
  display:flex;
  align-items:center;
  justify-content:center;
  overflow:hidden;
}

.video-loader {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100vw;
  height: 56.25vw;
  min-height: 100vh;
  min-width: 177.77vh;
  transform: translate(-50%, -50%);
  z-index: 1;
}

.video-loader iframe {
  width: 100%;
  height: 100%;
  border: none;
}

.loading-content{
  position:relative;
  z-index:2;
  text-align:center;
  color:#fff;
  padding: 20px;
}

.loading-logo{
  font-size:48px;
  font-weight:900;
  margin-bottom:20px;
  text-transform:uppercase;
  letter-spacing:3px;
  animation:pulse 2s ease-in-out infinite;
  text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
}

.loading-text{
  font-size:16px;
  opacity:0.9;
  margin-bottom:30px;
  text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
}

.skip-btn{
  position:fixed;
  bottom:30px;
  right:30px;
  background:rgba(255,255,255,0.2);
  backdrop-filter:blur(10px);
  color:#fff;
  border:2px solid rgba(255,255,255,0.5);
  padding:12px 30px;
  border-radius:30px;
  font-size:14px;
  font-weight:600;
  cursor:pointer;
  z-index:10;
  transition:all 0.3s ease;
  text-transform:uppercase;
  letter-spacing:1px;
}

.skip-btn:hover{
  background:rgba(255,255,255,0.3);
  transform:scale(1.05);
}

@keyframes pulse{
  0%,100%{transform:scale(1);opacity:1;}
  50%{transform:scale(1.05);opacity:0.8;}
}

.loading-screen.fade-out{
  opacity:0;
  pointer-events:none;
  transition:opacity 0.5s ease;
}
</style>

<script>
function skipLoading() {
  const loadingScreen = document.getElementById('loadingScreen');
  loadingScreen.classList.add('fade-out');
  setTimeout(() => {
    loadingScreen.style.display = 'none';
  }, 500);
}

setTimeout(() => {
  skipLoading();
}, 5000);
</script>
