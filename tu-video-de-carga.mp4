<div class="loading-screen" id="loadingScreen">
  <div class="video-loader">
    <video autoplay muted loop playsinline>
      <source src="https://drive.google.com/drive/home?dmr=1&ec=wgc-drive-%5Bmodule%5D-goto" type="video/mp4">
    </video>
  </div>
  <div class="loading-content">
    <div class="loading-logo">LIGA BICI</div>
    <div class="loading-text">Cargando experiencia...</div>
    <button class="skip-btn" id="skipBtn" onclick="skipLoading()">Saltar</button>
  </div>
</div>

<style>
.loading-screen{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:#000;
  z-index:9999;
  display:flex;
  align-items:center;
  justify-content:center;
  overflow:hidden;
}

.video-loader {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.video-loader video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.loading-content{
  position:relative;
  z-index:2;
  text-align:center;
  color:#fff;
  padding: 20px;
}

.loading-logo{
  font-size:48px;
  font-weight:900;
  margin-bottom:20px;
  text-transform:uppercase;
  letter-spacing:3px;
  animation:pulse 2s ease-in-out infinite;
  text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
}

.loading-text{
  font-size:16px;
  opacity:0.9;
  margin-bottom:30px;
  text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
}

.skip-btn{
  position:fixed;
  bottom:30px;
  right:30px;
  background:rgba(255,255,255,0.2);
  backdrop-filter:blur(10px);
  color:#fff;
  border:2px solid rgba(255,255,255,0.5);
  padding:12px 30px;
  border-radius:30px;
  font-size:14px;
  font-weight:600;
  cursor:pointer;
  z-index:10;
  transition:all 0.3s ease;
  text-transform:uppercase;
  letter-spacing:1px;
}

.skip-btn:hover{
  background:rgba(255,255,255,0.3);
  transform:scale(1.05);
}

@keyframes pulse{
  0%,100%{transform:scale(1);opacity:1;}
  50%{transform:scale(1.05);opacity:0.8;}
}

.loading-screen.fade-out{
  opacity:0;
  pointer-events:none;
  transition:opacity 0.5s ease;
}
</style>
