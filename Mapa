<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Liga Bici</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f5f5f5; }
.season-switcher { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; padding: 14px; background: #f5f5f5; position: sticky; top: 0; z-index: 100; }
.season-card { background: #e8e8e8; border: none; border-radius: 12px; padding: 12px; text-align: left; cursor: pointer; transition: all 0.15s; }
.season-card.active { background: #0b0b0c; color: white; }
.season-card .kicker { font-size: 9px; letter-spacing: 2px; text-transform: uppercase; opacity: 0.6; display: block; margin-bottom: 2px; }
.season-card strong { display: block; font-size: 14px; font-weight: 800; }
.season-card span { font-size: 12px; opacity: 0.7; }
.bottom-nav { position: fixed; bottom: 0; left: 0; right: 0; background: #0b0b0c; display: flex; height: 64px; z-index: 200; }
.nav-button { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; background: none; border: none; color: #888; font-size: 9px; cursor: pointer; text-transform: uppercase; }
.nav-button.active { color: white; }
.nav-button svg { width: 20px; height: 20px; }
.view-header { padding: 20px 14px 10px; }
.view-header .eyebrow { font-size: 11px; color: #a0a0a0; letter-spacing: 2px; text-transform: uppercase; font-weight: 600; }
.view-header h1 { font-size: 26px; font-weight: 900; margin-top: 2px; }
.filter-row { display: flex; gap: 8px; overflow-x: auto; padding: 0 14px 10px; }
.filter-row::-webkit-scrollbar { display: none; }
.filter-pill { background: #e8e8e8; border: none; border-radius: 20px; padding: 6px 14px; font-size: 12px; font-weight: 600; cursor: pointer; white-space: nowrap; color: #555; }
.filter-pill.active { background: #0b0b0c; color: white; }
.circ-card { background: white; border-radius: 12px; margin: 0 14px 12px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.08); cursor: pointer; }
.circ-header-bar { padding: 10px 14px 8px; display: flex; justify-content: space-between; align-items: center; }
.ch-label { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; }
.ch-badge { font-size: 10px; font-weight: 700; padding: 2px 10px; border-radius: 10px; text-transform: uppercase; background: #e02020; color: white; }
.circ-drawing { height: 130px; display: flex; align-items: center; justify-content: center; padding: 8px; background: #f8f8f8; position: relative; overflow: hidden; }
.circ-drawing svg { max-width: 100%; max-height: 100%; }
.circ-drawing img { width: 100%; height: 100%; object-fit: cover; }
.circ-info { padding: 10px 14px; }
.ci-name { font-size: 18px; font-weight: 900; }
.ci-record { font-size: 13px; color: #a0a0a0; float: right; margin-top: 2px; }
.ci-desc { font-size: 12px; color: #555; margin-top: 4px; line-height: 1.5; }
.ci-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
.ci-tag { font-size: 10px; font-weight: 700; padding: 3px 10px; border-radius: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
.tag-tranquilo { background: #dcfce7; color: #15803d; }
.tag-coches { background: #fef9c3; color: #854d0e; }
.tag-peatones { background: #dbeafe; color: #1e40af; }
.tag-dif-baja { background: #f0fdf4; color: #15803d; }
.tag-dif-media { background: #f3f4f6; color: #374151; }
.tag-dif-alta { background: #fee2e2; color: #b91c1c; }
.tag-riesgo-bajo { background: #f0fdf4; color: #15803d; }
.tag-riesgo-medio { background: #fff7ed; color: #c2410c; }
.tag-riesgo-alto { background: #fee2e2; color: #b91c1c; }
.google-earth-btn { position: absolute; bottom: 10px; right: 10px; background: #4285f4; color: white; padding: 8px 14px; border-radius: 8px; font-size: 12px; font-weight: bold; text-decoration: none; display: flex; align-items: center; gap: 6px; z-index: 20; cursor: pointer; border: none; box-shadow: 0 2px 6px rgba(0,0,0,0.3); }
.google-earth-btn:hover { background: #1e40ff; }
.screen { display: none; min-height: 100vh; padding-bottom: 88px; }
.screen.active { display: block; animation: fadeSlideIn 0.2s ease; }
@keyframes fadeSlideIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
</style>
</head>
<body>

<div id="screen-main" class="screen active">
  <div class="season-switcher" id="season-switcher"></div>
  <div class="app-content" id="app-content"></div>
  <nav class="bottom-nav" id="bottom-nav">
    <button class="nav-button active" data-view="inicio"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>Inicio</button>
    <button class="nav-button" data-view="pilotos"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>Pilotos</button>
    <button class="nav-button" data-view="puntos"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>Puntos</button>
    <button class="nav-button" data-view="circuitos"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 3v9l5 3"/></svg>Circuitos</button>
    <button class="nav-button" data-view="horarios"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><polyline points="12 6 12 12 16 14"/></svg>Horarios</button>
    <button class="nav-button" data-view="info"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>Info</button>
  </nav>
</div>

<script>
// URL de Google Earth corregida
const GOOGLE_EARTH_URL = 'https://earth.google.com/earth/d/13mVl3ODEJVU3lyRMRa3me1ygt0YkXWRK';

const CIRC_SVGS = {
  sanjose: {color:'#1e40ff', path:'M 60 90 L 20 70 L 15 40 L 40 15 L 100 10 L 175 25 L 195 55 L 180 85 L 130 95 Z'},
  andromeda: {color:'#059669', path:'M 50 85 L 20 60 L 20 35 L 50 15 L 100 10 L 160 20 L 190 45 L 185 75 L 150 90 L 90 95 Z'},
  maracana: {color:'#e02020', path:'M 70 85 L 30 65 L 30 45 L 60 20 L 110 15 L 170 30 L 185 60 L 160 85 Z'},
  benissano: {color:'#7c3aed', path:'M 30 90 L 20 55 L 30 25 L 70 10 L 140 10 L 185 30 L 195 65 L 175 88 L 120 95 L 60 92 Z'},
  poblanova: {color:'#0891b2', path:'M 55 90 L 18 68 L 15 38 L 38 15 L 90 8 L 155 18 L 188 50 L 175 82 L 130 95 Z'},
  cementerio: {color:'#dc2626', path:'M 40 88 L 18 62 L 18 38 L 35 18 L 80 10 L 145 15 L 185 40 L 190 72 L 165 90 L 100 95 Z'},
  benaguacil: {color:'#16a34a', path:'M 60 88 L 22 65 L 18 38 L 45 15 L 110 10 L 170 22 L 192 52 L 180 82 L 130 93 Z'},
  lliria: {color:'#ca8a04', path:'M 50 90 L 18 62 L 15 35 L 40 14 L 95 8 L 158 18 L 192 48 L 188 78 L 155 92 L 90 96 Z'},
  barranquet: {color:'#b45309', path:'M 35 88 L 15 60 L 18 30 L 50 12 L 115 8 L 175 22 L 195 55 L 185 82 L 140 94 L 75 96 Z'},
  sierraespada: {color:'#6b7280', path:'M 45 90 L 18 65 L 15 38 L 40 16 L 100 10 L 165 22 L 192 52 L 185 80 L 145 93 Z'},
  vistacalderona: {color:'#0284c7', path:'M 55 88 L 20 65 L 18 38 L 44 16 L 105 10 L 168 24 L 190 54 L 178 82 L 130 93 Z'},
  rascanya: {color:'#7c3aed', path:'M 65 88 L 22 65 L 18 38 L 42 16 L 100 10 L 162 22 L 188 52 L 178 82 L 125 93 Z'},
  llomallarga: {color:'#b91c1c', path:'M 30 90 L 15 50 L 20 20 L 60 10 L 120 15 L 180 40 L 195 70 L 160 90 Z'}
};

const CIRCUITS = [
  {id:'sanjose', name:'San José', record:"1'54.25\"", desc:'Circuito principal del centro sur de la Pobla.', zona:'peatones', dif:'media', riesgo:'bajo', hasMap: true},
  {id:'andromeda', name:'Andrómeda', record:"1'55.56\"", desc:'Trazado técnico en Maravisa.', zona:'coches', dif:'alta', riesgo:'medio'},
  {id:'maracana', name:'Maracaná', record:"1'02.17\"", desc:'Circuito corto y explosivo.', zona:'tranquilo', dif:'baja', riesgo:'bajo'},
  {id:'benissano', name:'Benissanó', record:"1'35.30\"", desc:'Entrada a Benissanó con trazada de velocidad.', zona:'coches', dif:'alta', riesgo:'alto'},
  {id:'poblanova', name:'Pobla Nova', record:"1'44.26\"", desc:'Circuito condicionado por lluvia.', zona:'peatones', dif:'media', riesgo:'medio'},
  {id:'cementerio', name:'Cementerio', record:"1'22.96\"", desc:'Circuito rápido con oportunidades de adelantamiento.', zona:'peatones', dif:'alta', riesgo:'alto'},
  {id:'benaguacil', name:'Benaguacil', record:"1'33.00\"", desc:'Entrada a Benaguacil con trazada de velocidad.', zona:'tranquilo', dif:'baja', riesgo:'bajo'},
  {id:'lliria', name:'Lliria', record:"1'27.63\"", desc:'Carrera de capital de comarca.', zona:'tranquilo', dif:'baja', riesgo:'bajo'},
  {id:'barranquet', name:'Barranquet', record:"1'25.61\"", desc:'Uno de los trazados más completos.', zona:'coches', dif:'alta', riesgo:'alto'},
  {id:'sierraespada', name:'Sierra Espada', record:"1'49.00\"", desc:'Maravisa norte. Circuito duro.', zona:'coches', dif:'alta', riesgo:'alto'},
  {id:'vistacalderona', name:'Vista Calderona', record:"1'22.43\"", desc:'Última carrera de la temporada 2.', zona:'coches', dif:'media', riesgo:'medio'},
  {id:'rascanya', name:'Rascanya', record:'Por añadir', desc:'Circuito histórico de temporada 1.', zona:'coches', dif:'media', riesgo:'medio'},
  {id:'llomallarga', name:'Lloma Llarga', record:"2'06.95\"", desc:'El circuito más lejano.', zona:'coches', dif:'alta', riesgo:'alto'}
];

const SEASONS = {
  t3: {key:'t3', label:'Temporada 3', year:'2026', kicker:'Actual', circs:['sanjose','cementerio','andromeda','llomallarga']},
  t2: {
    key:'t2', label:'Temporada 2', year:'2025', kicker:'Archivo', 
    circs:['sanjose','andromeda','maracana','benissano','poblanova','cementerio','benaguacil','lliria','barranquet','sierraespada','vistacalderona'],
    horarios: [
      {name:'San José', date:'21 sep', mes:'sep', dia:'21', circ:'San José', tipo:'carrera', status:'done', circId:'sanjose'},
      {name:'Andrómeda', date:'28 sep', mes:'sep', dia:'28', circ:'Andrómeda', tipo:'carrera', status:'done', circId:'andromeda'},
      {name:'Maracaná', date:'2 oct', mes:'oct', dia:'2', circ:'Maracaná', tipo:'carrera', status:'done', circId:'maracana'},
      {name:'Benissanó', date:'5 oct', mes:'oct', dia:'5', circ:'Benissanó', tipo:'carrera', status:'done', circId:'benissano'},
      {name:'Pobla Nova (Tiempos)', date:'19 oct', mes:'oct', dia:'19', circ:'Pobla Nova', tipo:'tiempos', status:'done', circId:'poblanova'},
      {name:'Pobla Nova Carrera', date:'25 oct', mes:'oct', dia:'25', circ:'Pobla Nova', tipo:'carrera', status:'done', circId:'poblanova'},
      {name:'Cementerio', date:'25 oct', mes:'oct', dia:'25', circ:'Cementerio', tipo:'carrera', status:'done', circId:'cementerio'},
      {name:'Práctica Cementerio', date:'9 nov', mes:'nov', dia:'9', circ:'Cementerio', tipo:'practica', status:'done', circId:'cementerio'},
      {name:'Benaguacil', date:'2 nov', mes:'nov', dia:'2', circ:'Benaguacil', tipo:'carrera', status:'done', circId:'benaguacil'},
      {name:'Llíria', date:'30 nov', mes:'nov', dia:'30', circ:'Llíria', tipo:'carrera', status:'done', circId:'lliria'},
      {name:'Barranquet', date:'6 dic', mes:'dic', dia:'6', circ:'Barranquet', tipo:'carrera', status:'done', circId:'barranquet'},
      {name:'Sierra Espada', date:'8 dic', mes:'dic', dia:'8', circ:'Sierra Espada', tipo:'carrera', status:'done', circId:'sierraespada'},
      {name:'Vista Calderona', date:'13 dic', mes:'dic', dia:'13', circ:'Vista Calderona', tipo:'carrera', status:'done', circId:'vistacalderona'}
    ]
  },
  t1: {key:'t1', label:'Temporada 1', year:'2024', kicker:'Archivo', circs:['sanjose','rascanya','cementerio','barranquet','andromeda','benissano','maracana']}
};

let curSeason = 't3';
let curView = 'inicio';
let circFilter = 'todos';

function circSVG(id) {
  var c = CIRC_SVGS[id] || {color:'#888', path:'M 50 85 L 20 55 L 80 15 L 160 20 L 190 60 L 150 90 Z'};
  return '<svg viewBox="0 0 210 105" xmlns="http://www.w3.org/2000/svg" style="max-width:100%;max-height:100%"><rect width="210" height="105" fill="#f8f8f8" rx="6"/><path d="'+c.path+'" fill="none" stroke="'+c.color+'" stroke-width="4.5" stroke-linejoin="round" stroke-linecap="round"/><path d="'+c.path+'" fill="'+c.color+'" fill-opacity="0.07"/></svg>';
}

function zonaBadge(z) {
  var m = {tranquilo:'tag-tranquilo', coches:'tag-coches', peatones:'tag-peatones'};
  var l = {tranquilo:'Tranquilo', coches:'Zona coches', peatones:'Zona peatones'};
  return '<span class="ci-tag '+m[z]+'">'+(l[z]||z)+'</span>';
}

function difBadge(d) {
  var m = {baja:'tag-dif-baja', media:'tag-dif-media', alta:'tag-dif-alta'};
  return '<span class="ci-tag '+m[d]+'">Dif. '+d+'</span>';
}

function riesgoBadge(r) {
  var m = {bajo:'tag-riesgo-bajo', medio:'tag-riesgo-medio', alto:'tag-riesgo-alto'};
  return '<span class="ci-tag '+m[r]+'">Riesgo '+r+'</span>';
}

function openGoogleEarth() {
  window.open(GOOGLE_EARTH_URL, '_blank', 'noopener,noreferrer');
}

function renderSwitcher() {
  var order = ['t1','t2','t3'];
  var html = order.map(function(k) {
    var s = SEASONS[k];
    return '<button class="season-card'+(curSeason===k?' active':'')+'" data-season="'+k+'"><span class="kicker">'+s.kicker+'</span><strong>'+s.label+'</strong><span>'+s.year+'</span></button>';
  }).join('');
  document.getElementById('season-switcher').innerHTML = html;
  document.querySelectorAll('.season-card').forEach(function(b) {
    b.onclick = function() { curSeason = b.dataset.season; render(); };
  });
}

function renderView() {
  var s = SEASONS[curSeason];
  var html = '';

  if (curView === 'circuitos') {
    html += '<div class="view-header"><p class="eyebrow">Trazados</p><h1>Circuitos</h1></div>';
    html += '<div class="filter-row">';
    html += '<button class="filter-pill'+(circFilter==='todos'?' active':'')+'" onclick="setCircFilter(\'todos\')">Todos</button>';
    html += '<button class="filter-pill'+(circFilter==='baja'?' active':'')+'" onclick="setCircFilter(\'baja\')">Fácil</button>';
    html += '<button class="filter-pill'+(circFilter==='media'?' active':'')+'" onclick="setCircFilter(\'media\')">Media</button>';
    html += '<button class="filter-pill'+(circFilter==='alta'?' active':'')+'" onclick="setCircFilter(\'alta\')">Alta</button>';
    html += '</div>';
    
    s.circs.forEach(function(id) {
      var c = CIRCUITS.find(function(x) { return x.id === id; });
      if (!c) return;
      
      if (circFilter !== 'todos' && c.dif !== circFilter) return;
      
      var drawingHtml = '';
      
      // Lógica especial para San José en Temporada 2 con imagen y botón Google Earth
      if (c.id === 'sanjose' && curSeason === 't2') {
        drawingHtml = '<div class="circ-drawing" style="padding:0;position:relative;">' +
          '<img src="sanjose_t2.png" alt="Circuito San José T2" style="width:100%;height:100%;object-fit:cover;" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\';">' +
          '<div style="display:none;align-items:center;justify-content:center;height:100%;background:#f8f8f8;">' + circSVG(c.id) + '</div>' +
          '<button class="google-earth-btn" onclick="event.stopPropagation();openGoogleEarth();">🌍 Google Earth</button>' +
          '</div>';
      } else {
        drawingHtml = '<div class="circ-drawing">' + circSVG(c.id) + '</div>';
      }
      
      html += '<div class="circ-card"><div class="circ-header-bar"><span class="ch-label">Circuito</span><span class="ch-badge">CIRCUITO</span></div>' +
        drawingHtml +
        '<div class="circ-info"><span class="ci-record">'+c.record+'</span><div class="ci-name">'+c.name+'</div>' +
        '<div class="ci-desc">'+c.desc+'</div><div class="ci-tags">'+zonaBadge(c.zona)+difBadge(c.dif)+riesgoBadge(c.riesgo)+'</div></div></div>';
    });
  }

  document.getElementById('app-content').innerHTML = html;
  window.scrollTo(0,0);
}

function render() {
  renderSwitcher();
  renderView();
  document.querySelectorAll('.nav-button').forEach(function(b) {
    b.classList.toggle('active', b.dataset.view === curView);
  });
}

function setCircFilter(f) {
  circFilter = f;
  renderView();
}

document.querySelectorAll('.nav-button').forEach(function(b) {
  b.onclick = function() { curView = b.dataset.view; render(); };
});

render();
</script>

</body>
</html>
